#--------------------------------------------------------------------
# PLANTILLA DE CONFIGURACIÓN PARA PRODUCCIÓN — GIBI-ITSI
# Copia este archivo como ".env" y rellena todos los valores.
# ¡NUNCA subas el .env real a Git ni lo dejes expuesto en el servidor!
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENTORNO
# Opciones: 'production' | 'development' | 'testing'
# En InfinityFree SIEMPRE debe ser 'production'
#--------------------------------------------------------------------
CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# BASE DE DATOS (InfinityFree)
# Los valores exactos los encuentras en:
# Panel InfinityFree → MySQL Databases → clic en tu BD
#--------------------------------------------------------------------
database.default.hostname = sql200.infinityfree.com
database.default.database = if0_XXXXXXXX_bienestar
database.default.username = if0_XXXXXXXX
database.default.password = TU_PASSWORD_AQUI
database.default.DBDriver = MySQLi
database.default.port     = 3306

#--------------------------------------------------------------------
# EMAIL / SMTP (Gmail)
# IMPORTANTE: InfinityFree bloquea el puerto 587.
# Usa puerto 465 con crypto = ssl (SSL implícito).
#
# Además, necesitas una "Contraseña de aplicación" de Google:
# Mi cuenta Google → Seguridad → Contraseñas de aplicaciones
#--------------------------------------------------------------------
EMAIL_SMTP_HOST   = smtp.gmail.com
EMAIL_SMTP_PORT   = 465
EMAIL_SMTP_CRYPTO = ssl
EMAIL_SMTP_USER   = tu.correo@gmail.com
EMAIL_SMTP_PASS   = xxxx_xxxx_xxxx_xxxx
EMAIL_FROM_NAME   = "Unidad de Bienestar - ITSI"
